"use client";

import { useRouter } from "next/navigation";
import { createClient } from "@/lib/supabase/client";

export default function PanelShell({
  title,
  children,
}: {
  title: string;
  children: React.ReactNode;
}) {
  const router = useRouter();

  async function signOut() {
    const supabase = createClient();
    await supabase.auth.signOut();
    router.push("/login");
  }

  return (
    <div className="min-h-screen">
      <header className="border-b border-clinical-100 bg-white px-6 py-3 flex items-center justify-between">
        <div>
          <p className="text-xs text-clinical-600">Izungo Medical Centre</p>
          <h1 className="font-display text-lg text-clinical-900">{title}</h1>
        </div>
        <button onClick={signOut} className="text-sm text-clinical-600 hover:text-clinical-900">
          Sign out
        </button>
      </header>
      <main className="p-6">{children}</main>
    </div>
  );
}
